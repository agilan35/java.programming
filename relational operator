public class relationaloperator {
    public static void main(String[] args) {
        int a = 10;
        int b = 5;
        System.out.println("\nRelational Operators");
        System.out.println("a == b : " + (a == b));
        System.out.println("a != b : " + (a != b));
        System.out.println("a > b : " + (a > b));
        System.out.println("a < b : " + (a < b));
        System.out.println("a >= b : " + (a >= b));
        System.out.println("a <= b : " + (a <= b));}}
